{
	"json": {
		"useTabs": true,
		"associations": ["**/*.{json,jsonc}"]
	},
	"malva": {
		"useTabs": true,
		"indentWidth": 2
	},
	"markdown": {},
	"markup": {},
	"oxc": {
		"indentStyle": "tab",
		"lineWidth": 120,
		"experimentalSortImports": {
			"internalPattern": ["@/", "@proto/"],
			"groups": [
				["type-builtin", "type-external", "value-builtin", "value-external"],
				["type-internal", "value-internal"],
				["type-parent", "type-sibling", "type-index", "value-parent", "value-sibling", "value-index"],
				["side-effect-style"],
				["unknown"]
			]
		},
		"associations": ["**/*.{js,jsx,ts,tsx}"]
	},
	"yaml": {},
	"excludes": ["**/*-lock.yaml", "**/.next", "**/dist", "**/migrations", "**/node_modules"],
	"plugins": [
		"https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
		"https://plugins.dprint.dev/g-plane/malva-v0.15.2.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.25.3.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
		"https://plugins.dprint.dev/json-0.21.1.wasm",
		"https://plugins.dprint.dev/markdown-0.20.0.wasm",
		"https://plugins.dprint.dev/oxc-0.6.0.wasm"
	]
}
